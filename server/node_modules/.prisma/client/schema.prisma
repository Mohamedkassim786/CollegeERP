generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                      @id @default(autoincrement())
  username               String                   @unique
  password               String
  role                   String
  fullName               String?
  email                  String?                  @unique
  phoneNumber            String?
  department             String?
  designation            String?
  lastPasswordChange     DateTime?                @default(now())
  isDisabled             Boolean                  @default(false)
  forcePasswordChange    Boolean                  @default(false)
  lastLogin              DateTime?
  createdAt              DateTime                 @default(now())
  // New fields added in v1.5
  employeeId             String?                  @unique
  dateOfBirth            DateTime?
  photoUrl               String?
  isHOD                  Boolean                  @default(false)
  isFirstLogin           Boolean                  @default(true)
  activityPerformed      ActivityLog[]            @relation("PerformedBy")
  announcements          Announcement[]           @relation("PostedBy")
  externalStaffTasks     ExternalMarkAssignment[] @relation("ExternalStaffAssignments")
  facultyAbsences        FacultyAbsence[]
  marksApproved          Marks[]                  @relation("MarksApprover")
  materials              Material[]               @relation("Instructor")
  takenAttendance        StudentAttendance[]
  substitutions          Substitution[]
  timetables             Timetable[]
  externalMarksSubmitted ExternalMark[]           @relation("ExternalEvaluator")
  examSessions           ExamSession[]            @relation("CreatedSessions")
  facultyAssignments     FacultyAssignment[]      @relation("FacultyToAssignment")
  hodNotifications       Notification[]           @relation("HODNotifications")
  facultyNotifications   Notification[]           @relation("FacultyNotifications")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  description String
  performedBy Int
  targetId    Int?
  timestamp   DateTime @default(now())
  performer   User     @relation("PerformedBy", fields: [performedBy], references: [id])
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @unique
  hodId     Int?
  sections  String   @default("A,B,C")
  years     String   @default("2,3,4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 2 Relational Structure
  sectionRefs Section[]
  students    Student[]
}

model AcademicYear {
  id       Int     @id @default(autoincrement())
  year     String
  isActive Boolean @default(false)

  sections Section[]
  students Student[]
}

model Section {
  id             Int    @id @default(autoincrement())
  name           String // e.g., "A", "B", "C"
  semester       Int
  type           String // "COMMON" | "DEPARTMENT"
  departmentId   Int? // Nullable for "COMMON"
  academicYearId Int

  department   Department?  @relation(fields: [departmentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  students     Student[]

  @@unique([name, semester, departmentId, academicYearId])
  @@index([semester, type])
}

model Student {
  id              Int                   @id @default(autoincrement())
  rollNo          String                @unique
  registerNumber  String?               @unique
  name            String
  department      String?
  year            Int
  section         String
  semester        Int
  regulation      String?               @default("2021")
  batch           String?
  createdAt       DateTime              @default(now())
  password        String? // null = default DoB password
  arrears         Arrear[]
  marks           Marks[]
  results         SemesterResult[]
  attendance      StudentAttendance[]
  dummyMappings   SubjectDummyMapping[]
  hallAllocations HallAllocation[]

  // Phase 2 Relational Fields (Nullable for migration phase)
  departmentId    Int?
  sectionId       Int?
  currentSemester Int?
  academicYearId  Int?
  batchYear       String?
  status          String  @default("ACTIVE")
  admissionYear   String?
  photo           String?
  dateOfBirth     String?
  gender          String?
  bloodGroup      String?
  nationality     String?
  phoneNumber     String?
  email           String?
  address         String?
  city            String?
  district        String?
  state           String?
  pincode         String?
  fatherName      String?
  fatherPhone     String?
  motherName      String?
  motherPhone     String?
  guardianName    String?
  guardianPhone   String?

  departmentRef Department?             @relation(fields: [departmentId], references: [id])
  sectionRef    Section?                @relation(fields: [sectionId], references: [id])
  academicYear  AcademicYear?           @relation(fields: [academicYearId], references: [id])
  eligibility   AttendanceEligibility[]

  @@index([department, year, section, semester]) // Legacy
  @@index([departmentId, currentSemester])
  @@index([sectionId])
}

model Timetable {
  id            Int            @id @default(autoincrement())
  department    String?
  year          Int
  semester      Int
  section       String
  day           String
  period        Int
  duration      Int            @default(1)
  type          String?
  subjectName   String?
  facultyName   String?
  room          String?
  subjectId     Int?
  facultyId     Int?
  updatedAt     DateTime       @updatedAt
  substitutions Substitution[]
  faculty       User?          @relation(fields: [facultyId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])

  @@unique([department, year, semester, section, day, period])
}

model Subject {
  id                 Int                      @id @default(autoincrement())
  code               String                   @unique
  name               String
  shortName          String?
  department         String?
  semester           Int
  credits            Int                      @default(3)
  type               String                   @default("DEPARTMENT")
  subjectCategory    String                   @default("THEORY")
  theoryCredit       Int?
  labCredit          Int?
  hasRelativeGrade   Boolean                  @default(false)
  arrears            Arrear[]
  externalStaffTasks ExternalMarkAssignment[]
  facultyAssignments FacultyAssignment[]
  marks              Marks[]
  materials          Material[]
  attendance         StudentAttendance[]
  timetables         Timetable[]
  dummyMappings      SubjectDummyMapping[]
  externalMarks      ExternalMark[]
  examSessionLinks   ExamSessionSubjects[]
  hallAllocations    HallAllocation[]
  eligibility        AttendanceEligibility[]
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  category   String   @default("GENERAL")
  department String?
  year       Int?
  semester   Int?
  section    String?
  postedBy   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("PostedBy", fields: [postedBy], references: [id])
}

model Material {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  fileUrl      String?
  subjectId    Int
  instructorId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  instructor   User     @relation("Instructor", fields: [instructorId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])
}

model FacultyAssignment {
  id         Int     @id @default(autoincrement())
  facultyId  Int
  subjectId  Int
  section    String
  department String?
  subject    Subject @relation(fields: [subjectId], references: [id])
  faculty    User    @relation("FacultyToAssignment", fields: [facultyId], references: [id])
}

model Marks {
  id              Int    @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  cia1_test       Float?
  cia1_assignment Float?
  cia1_attendance Float?
  cia2_test       Float?
  cia2_assignment Float?
  cia2_attendance Float?
  cia3_test       Float?
  cia3_assignment Float?
  cia3_attendance Float?

  // LAB specific fields
  lab_attendance  Float?
  lab_observation Float?
  lab_record      Float?
  lab_model       Float?

  // INTEGRATED specific fields
  lab_assessment Float?

  internal        Float?
  isLocked        Boolean      @default(false)
  isApproved      Boolean      @default(false)
  isLocked_cia1   Boolean      @default(false)
  isLocked_cia2   Boolean      @default(false)
  isLocked_cia3   Boolean      @default(false)
  isApproved_cia1 Boolean      @default(false)
  isApproved_cia2 Boolean      @default(false)
  isApproved_cia3 Boolean      @default(false)
  approvedBy      Int?
  approvedAt      DateTime?
  updatedAt       DateTime     @updatedAt
  endSemMarks     EndSemMarks?
  approver        User?        @relation("MarksApprover", fields: [approvedBy], references: [id])
  subject         Subject      @relation(fields: [subjectId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
  @@index([isApproved, isLocked]) // New: Optimization for pending marks
}

model EndSemMarks {
  id                 Int      @id @default(autoincrement())
  marksId            Int      @unique
  externalMarks      Float?
  totalMarks         Float?
  grade              String?
  resultStatus       String?
  isPublished        Boolean  @default(false)
  isLocked           Boolean  @default(false)
  attendanceSnapshot Float?
  updatedAt          DateTime @updatedAt
  marks              Marks    @relation(fields: [marksId], references: [id])

  @@index([marksId])
}

model GradeSettings {
  id            Int      @id @default(autoincrement())
  regulation    String
  grade         String
  minPercentage Float
  maxPercentage Float
  gradePoint    Int
  resultStatus  String   @default("PASS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([regulation, grade])
}

model SemesterControl {
  id            Int      @id @default(autoincrement())
  department    String
  year          Int
  semester      Int
  section       String
  markEntryOpen Boolean  @default(false)
  isPublished   Boolean  @default(false)
  isLocked      Boolean  @default(false)
  isFrozen      Boolean  @default(false)
  actionLogs    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([department, year, semester, section])
}

model SemesterResult {
  id            Int      @id @default(autoincrement())
  studentId     Int
  semester      Int
  gpa           Float
  cgpa          Float
  totalCredits  Int
  earnedCredits Int
  resultStatus  String
  isLocked      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, semester])
}

model Arrear {
  id           Int             @id @default(autoincrement())
  studentId    Int
  subjectId    Int
  semester     Int
  attemptCount Int             @default(1)
  isCleared    Boolean         @default(false)
  clearedInSem Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  subject      Subject         @relation(fields: [subjectId], references: [id])
  student      Student         @relation(fields: [studentId], references: [id])
  attempts     ArrearAttempt[]

  @@unique([studentId, subjectId])
}

model ArrearAttempt {
  id            Int       @id @default(autoincrement())
  arrearId      Int
  semester      Int
  internalMarks Float?
  externalMarks Float?
  totalMarks    Float?
  grade         String?
  resultStatus  String?
  examDate      DateTime?
  createdAt     DateTime  @default(now())
  arrear        Arrear    @relation(fields: [arrearId], references: [id])
}

model ExternalMarkAssignment {
  id        Int      @id @default(autoincrement())
  staffId   Int
  subjectId Int
  component String   @default("THEORY") // "THEORY" or "LAB"
  deadline  DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject  @relation(fields: [subjectId], references: [id])
  staff     User     @relation("ExternalStaffAssignments", fields: [staffId], references: [id])

  @@unique([staffId, subjectId, component])
}

model FacultyAbsence {
  id        Int      @id @default(autoincrement())
  facultyId Int
  date      String
  period    Int      @default(0)
  reason    String?
  createdAt DateTime @default(now())
  faculty   User     @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, date, period])
}

model Substitution {
  id                  Int       @id @default(autoincrement())
  timetableId         Int
  substituteFacultyId Int
  date                String
  createdAt           DateTime  @default(now())
  substituteFaculty   User      @relation(fields: [substituteFacultyId], references: [id])
  timetable           Timetable @relation(fields: [timetableId], references: [id])

  @@unique([timetableId, date])
}

model StudentAttendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  facultyId Int
  date      String
  period    Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  faculty   User     @relation(fields: [facultyId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, subjectId, date, period])
}

model SubjectDummyMapping {
  id                 Int      @id @default(autoincrement())
  studentId          Int
  originalRegisterNo String
  subjectId          Int
  subjectCode        String
  department         String
  semester           Int
  section            String
  academicYear       String
  dummyNumber        String?
  answerScriptNo     String?
  isAbsent           Boolean  @default(false)
  boardCode          String?
  qpCode             String?
  marks              Float?
  mappingLocked      Boolean  @default(false)
  createdAt          DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
  @@unique([subjectId, dummyNumber])
  @@index([dummyNumber])
  @@index([studentId])
  @@index([subjectId])
}

model ExternalMark {
  id                  Int      @id @default(autoincrement())
  subjectId           Int
  dummyNumber         String
  component           String   @default("THEORY") // "THEORY" or "LAB"
  rawExternal100      Float
  convertedExternal60 Float
  submittedBy         Int
  submittedAt         DateTime @default(now())
  locked              Boolean  @default(false)
  isApproved          Boolean  @default(false)

  subject   Subject @relation(fields: [subjectId], references: [id])
  evaluator User    @relation("ExternalEvaluator", fields: [submittedBy], references: [id])

  @@unique([subjectId, dummyNumber, component])
  @@index([dummyNumber])
  @@index([subjectId])
}

model ExamSession {
  id        Int      @id @default(autoincrement())
  examName  String
  examDate  DateTime
  session   String // "FN" or "AN"
  examMode  String   @default("CIA")
  isLocked  Boolean  @default(false)
  createdBy Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author      User                  @relation("CreatedSessions", fields: [createdBy], references: [id])
  subjects    ExamSessionSubjects[]
  allocations HallAllocation[]
}

model ExamSessionSubjects {
  id            Int @id @default(autoincrement())
  examSessionId Int
  subjectId     Int

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, subjectId])
}

model Hall {
  id            Int      @id @default(autoincrement())
  hallName      String
  blockName     String
  totalRows     Int? // Legacy (moving to columns)
  benchesPerRow Int? // Legacy (moving to columns)
  totalBenches  Int      @default(0)
  capacityCIA   Int      @default(0)
  capacityEND   Int      @default(0)
  capacity      Int? // Legacy
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  columns     HallColumn[]
  allocations HallAllocation[]
}

model HallColumn {
  id        Int         @id @default(autoincrement())
  hallId    Int
  label     String
  benches   Int // Number of benches (legacy/cache)
  hall      Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
  benchData HallBench[]
}

model HallBench {
  id          Int        @id @default(autoincrement())
  columnId    Int
  benchNumber Int // 1, 2, 3...
  capacity    Int        @default(2) // 1 or 2
  column      HallColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([columnId, benchNumber])
}

model HallAllocation {
  id            Int      @id @default(autoincrement())
  examSessionId Int
  hallId        Int
  studentId     Int
  subjectId     Int
  department    String
  year          Int
  seatNumber    String
  rowNumber     Int? // Make optional for column-based flexibility
  columnNumber  Int? // Make optional for column-based flexibility
  benchIndex    Int? // New: position in column (1, 2, 3...)
  columnLabel   String? // New: A, B, C...
  createdAt     DateTime @default(now())

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  hall        Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, studentId])
  @@unique([examSessionId, hallId, seatNumber])
}

model MarkAuditLog {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  oldValue  Float?
  newValue  Float?
  changedBy Int
  timestamp DateTime @default(now())
}

// ── New in v1.5 ────────────────────────────────────────────────────────────────

/// Attendance-based exam eligibility (SA Check)
model AttendanceEligibility {
  id                 String   @id @default(cuid())
  studentId          Int
  subjectId          Int
  semester           Int
  attendancePercent  Float
  /// ELIGIBLE | CONDONATION | DETAINED
  status             String
  isException        Boolean  @default(false)
  exceptionReason    String?
  exceptionGrantedBy Int?
  isLocked           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, semester])
  @@index([semester, status])
}

/// HOD notification (sent when attendance is not submitted by faculty)
model Notification {
  id        String   @id @default(cuid())
  hodId     Int
  facultyId Int
  message   String
  isRead    Boolean  @default(false)
  /// ATTENDANCE_MISSING | MARKS_PENDING | GENERAL
  type      String   @default("ATTENDANCE_MISSING")
  createdAt DateTime @default(now())
  hod       User     @relation("HODNotifications", fields: [hodId], references: [id], onDelete: Cascade)
  faculty   User     @relation("FacultyNotifications", fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([hodId, isRead])
}
