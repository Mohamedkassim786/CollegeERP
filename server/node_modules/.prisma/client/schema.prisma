generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                      @id @default(autoincrement())
  username               String                   @unique
  password               String
  role                   String
  fullName               String?
  email                  String?                  @unique
  phoneNumber            String?
  department             String?
  designation            String?
  lastPasswordChange     DateTime?                @default(now())
  isDisabled             Boolean                  @default(false)
  forcePasswordChange    Boolean                  @default(false)
  lastLogin              DateTime?
  createdAt              DateTime                 @default(now())
  activityPerformed      ActivityLog[]            @relation("PerformedBy")
  announcements          Announcement[]           @relation("PostedBy")
  examSessions           ExamSession[]            @relation("CreatedSessions")
  externalMarksSubmitted ExternalMark[]           @relation("ExternalEvaluator")
  externalStaffTasks     ExternalMarkAssignment[] @relation("ExternalStaffAssignments")
  marksApproved          Marks[]                  @relation("MarksApprover")
}

model Faculty {
  id                   Int                 @id @default(autoincrement())
  staffId              String              @unique
  password             String
  fullName             String
  department           String?
  role                 String              @default("FACULTY")
  photo                String?
  dateOfBirth          String?
  gender               String?
  bloodGroup           String?
  phone                String?
  email                String?
  designation          String?
  qualification        String?
  address              String?
  departmentId         Int?
  isActive             Boolean             @default(true)
  isFirstLogin         Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  absences             FacultyAbsence[]
  assignments          FacultyAssignment[]
  materials            Material[]          @relation("FacultyMaterials")
  facultyNotifications Notification[]      @relation("FacultyNotifications")
  hodNotifications     Notification[]      @relation("HODNotifications")
  takenAttendance      StudentAttendance[]
  substitutions        Substitution[]      @relation("SubstituteFaculty")
  timetables           Timetable[]
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  description String
  performedBy Int
  targetId    Int?
  timestamp   DateTime @default(now())
  performer   User     @relation("PerformedBy", fields: [performedBy], references: [id])
}

model Department {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String?   @unique
  type        String    @default("Academic")
  hodId       Int?
  hodName     String?
  degree      String    @default("B.E.")
  sections    String    @default("A,B,C")
  years       String    @default("2,3,4")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sectionRefs Section[]
  students    Student[]
}

model AcademicYear {
  id       Int       @id @default(autoincrement())
  year     String
  isActive Boolean   @default(false)
  sections Section[]
  students Student[]
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id             Int          @id @default(autoincrement())
  name           String
  semester       Int
  type           String
  departmentId   Int?
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  department     Department?  @relation(fields: [departmentId], references: [id])
  students       Student[]

  @@unique([name, semester, departmentId, academicYearId])
  @@index([semester, type])
}

model Student {
  id              Int                     @id @default(autoincrement())
  rollNo          String                  @unique
  registerNumber  String?                 @unique
  name            String
  department      String?
  year            Int
  section         String
  semester        Int
  regulation      String?                 @default("2021")
  batch           String?
  createdAt       DateTime                @default(now())
  departmentId    Int?
  sectionId       Int?
  currentSemester Int?
  academicYearId  Int?
  batchYear       String?
  status          String                  @default("ACTIVE")
  address         String?
  admissionYear   String?
  bloodGroup      String?
  city            String?
  dateOfBirth     String?
  district        String?
  email           String?
  fatherName      String?
  fatherPhone     String?
  gender          String?
  guardianName    String?
  guardianPhone   String?
  motherName      String?
  motherPhone     String?
  nationality     String?
  phoneNumber     String?
  photo           String?
  pincode         String?
  state           String?
  password        String?
  arrears         Arrear[]
  eligibility     AttendanceEligibility[]
  hallAllocations HallAllocation[]
  marks           Marks[]
  results         SemesterResult[]
  academicYear    AcademicYear?           @relation(fields: [academicYearId], references: [id])
  sectionRef      Section?                @relation(fields: [sectionId], references: [id])
  departmentRef   Department?             @relation(fields: [departmentId], references: [id])
  attendance      StudentAttendance[]
  dummyMappings   SubjectDummyMapping[]

  @@index([department, year, section, semester])
  @@index([departmentId, currentSemester])
  @@index([sectionId])
}

model Timetable {
  id            Int            @id @default(autoincrement())
  department    String?
  year          Int
  semester      Int
  section       String
  day           String
  period        Int
  duration      Int            @default(1)
  type          String?
  subjectName   String?
  facultyName   String?
  room          String?
  subjectId     Int?
  facultyId     Int?
  updatedAt     DateTime       @updatedAt
  substitutions Substitution[]
  subject       Subject?       @relation(fields: [subjectId], references: [id])
  faculty       Faculty?       @relation(fields: [facultyId], references: [id])

  @@unique([department, year, semester, section, day, period])
}

model Subject {
  id                 Int                      @id @default(autoincrement())
  code               String                   @unique
  name               String
  shortName          String?
  department         String?
  semester           Int
  credits            Int                      @default(3)
  type               String                   @default("DEPARTMENT")
  subjectCategory    String                   @default("THEORY")
  theoryCredit       Int?
  labCredit          Int?
  hasRelativeGrade   Boolean                  @default(false)
  arrears            Arrear[]
  eligibility        AttendanceEligibility[]
  examSessionLinks   ExamSessionSubjects[]
  externalMarks      ExternalMark[]
  externalStaffTasks ExternalMarkAssignment[]
  facultyAssignments FacultyAssignment[]
  hallAllocations    HallAllocation[]
  marks              Marks[]
  materials          Material[]
  attendance         StudentAttendance[]
  dummyMappings      SubjectDummyMapping[]
  timetables         Timetable[]
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  category   String   @default("GENERAL")
  department String?
  year       Int?
  semester   Int?
  section    String?
  postedBy   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("PostedBy", fields: [postedBy], references: [id])
}

model Material {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  fileUrl      String?
  subjectId    Int
  instructorId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  instructor   Faculty  @relation("FacultyMaterials", fields: [instructorId], references: [id], onDelete: Cascade)
}

model FacultyAssignment {
  id         Int     @id @default(autoincrement())
  facultyId  Int
  subjectId  Int
  section    String
  department String?
  faculty    Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject    Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Marks {
  id              Int          @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  cia1_test       Float?
  cia1_assignment Float?
  cia1_attendance Float?
  cia2_test       Float?
  cia2_assignment Float?
  cia2_attendance Float?
  cia3_test       Float?
  cia3_assignment Float?
  cia3_attendance Float?
  lab_attendance  Float?
  lab_observation Float?
  lab_record      Float?
  lab_model       Float?
  lab_assessment  Float?
  internal        Float?
  isLocked        Boolean      @default(false)
  isApproved      Boolean      @default(false)
  isLocked_cia1   Boolean      @default(false)
  isLocked_cia2   Boolean      @default(false)
  isLocked_cia3   Boolean      @default(false)
  isApproved_cia1 Boolean      @default(false)
  isApproved_cia2 Boolean      @default(false)
  isApproved_cia3 Boolean      @default(false)
  approvedBy      Int?
  approvedAt      DateTime?
  updatedAt       DateTime     @updatedAt
  endSemMarks     EndSemMarks?
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  approver        User?        @relation("MarksApprover", fields: [approvedBy], references: [id])

  @@unique([studentId, subjectId])
  @@index([studentId, isApproved])
  @@index([subjectId])
}

model EndSemMarks {
  id                 Int      @id @default(autoincrement())
  marksId            Int      @unique
  externalMarks      Float?
  totalMarks         Float?
  grade              String?
  resultStatus       String?
  isPublished        Boolean  @default(false)
  isLocked           Boolean  @default(false)
  attendanceSnapshot Float?
  updatedAt          DateTime @updatedAt
  marks              Marks    @relation(fields: [marksId], references: [id], onDelete: Cascade)

  @@index([marksId])
}

model GradeSettings {
  id            Int      @id @default(autoincrement())
  regulation    String
  grade         String
  minPercentage Float
  maxPercentage Float
  gradePoint    Int
  resultStatus  String   @default("PASS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([regulation, grade])
}

model SemesterControl {
  id            Int       @id @default(autoincrement())
  department    String
  year          Int
  semester      Int
  section       String
  markEntryOpen Boolean   @default(false)
  isPublished   Boolean   @default(false)
  isLocked      Boolean   @default(false)
  isFrozen      Boolean   @default(false)
  publishedAt   DateTime?
  publishedBy   Int?
  actionLogs    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([department, year, semester, section])
}

model SemesterResult {
  id            Int      @id @default(autoincrement())
  studentId     Int
  semester      Int
  gpa           Float
  cgpa          Float
  totalCredits  Int
  earnedCredits Int
  resultStatus  String
  isLocked      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semester])
}

model Arrear {
  id           Int             @id @default(autoincrement())
  studentId    Int
  subjectId    Int
  semester     Int
  attemptCount Int             @default(1)
  isCleared    Boolean         @default(false)
  clearedInSem Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attempts     ArrearAttempt[]

  @@unique([studentId, subjectId])
}

model ArrearAttempt {
  id            Int       @id @default(autoincrement())
  arrearId      Int
  semester      Int
  internalMarks Float?
  externalMarks Float?
  totalMarks    Float?
  grade         String?
  resultStatus  String?
  examDate      DateTime?
  createdAt     DateTime  @default(now())
  arrear        Arrear    @relation(fields: [arrearId], references: [id], onDelete: Cascade)
}

model ExternalMarkAssignment {
  id        Int      @id @default(autoincrement())
  staffId   Int
  subjectId Int
  component String   @default("THEORY")
  deadline  DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     User     @relation("ExternalStaffAssignments", fields: [staffId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@unique([staffId, subjectId, component])
}

model FacultyAbsence {
  id        Int      @id @default(autoincrement())
  facultyId Int
  date      String
  period    Int      @default(0)
  reason    String?
  createdAt DateTime @default(now())
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([facultyId, date, period])
}

model Substitution {
  id                  Int       @id @default(autoincrement())
  timetableId         Int
  substituteFacultyId Int
  date                String
  createdAt           DateTime  @default(now())
  timetable           Timetable @relation(fields: [timetableId], references: [id])
  substituteFaculty   Faculty   @relation("SubstituteFaculty", fields: [substituteFacultyId], references: [id])

  @@unique([timetableId, date])
}

model StudentAttendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  facultyId Int
  date      String
  period    Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, date, period])
}

model SubjectDummyMapping {
  id                 Int      @id @default(autoincrement())
  studentId          Int
  originalRegisterNo String
  subjectId          Int
  subjectCode        String
  department         String
  semester           Int
  section            String
  academicYear       String
  dummyNumber        String?
  answerScriptNo     String?
  isAbsent           Boolean  @default(false)
  boardCode          String?
  qpCode             String?
  marks              Float?
  mappingLocked      Boolean  @default(false)
  createdAt          DateTime @default(now())
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId])
  @@unique([subjectId, dummyNumber])
  @@index([dummyNumber])
  @@index([studentId])
  @@index([subjectId])
}

model ExternalMark {
  id                  Int      @id @default(autoincrement())
  subjectId           Int
  dummyNumber         String
  component           String   @default("THEORY")
  rawExternal100      Float
  convertedExternal60 Float
  submittedBy         Int
  submittedAt         DateTime @default(now())
  locked              Boolean  @default(false)
  isApproved          Boolean  @default(false)
  status              String   @default("PENDING")
  evaluator           User     @relation("ExternalEvaluator", fields: [submittedBy], references: [id])
  subject             Subject  @relation(fields: [subjectId], references: [id])

  @@unique([subjectId, dummyNumber, component])
  @@index([dummyNumber])
  @@index([subjectId])
}

model ExamSession {
  id          Int                   @id @default(autoincrement())
  examName    String
  examDate    DateTime?
  month       String?
  year        String?
  session     String?
  examMode    String                @default("CIA")
  isLocked    Boolean               @default(false)
  createdBy   Int
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  author      User                  @relation("CreatedSessions", fields: [createdBy], references: [id])
  subjects    ExamSessionSubjects[]
  halls       Hall[]
  allocations HallAllocation[]
}

model ExamSessionSubjects {
  id            Int         @id @default(autoincrement())
  examSessionId Int
  subjectId     Int
  examDate      DateTime?
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examSession   ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, subjectId])
}

model Hall {
  id            Int              @id @default(autoincrement())
  hallName      String
  blockName     String
  examSessionId Int?
  totalRows     Int?
  benchesPerRow Int?
  totalBenches  Int              @default(0)
  capacityCIA   Int              @default(0)
  capacityEND   Int              @default(0)
  capacity      Int?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  examSession   ExamSession?     @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  allocations   HallAllocation[]
  columns       HallColumn[]
}

model HallColumn {
  id        Int         @id @default(autoincrement())
  hallId    Int
  label     String
  benches   Int
  benchData HallBench[]
  hall      Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

model HallBench {
  id          Int        @id @default(autoincrement())
  columnId    Int
  benchNumber Int
  capacity    Int        @default(2)
  column      HallColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([columnId, benchNumber])
}

model HallAllocation {
  id            Int         @id @default(autoincrement())
  examSessionId Int
  hallId        Int
  studentId     Int
  subjectId     Int
  department    String
  year          Int
  seatNumber    String
  rowNumber     Int?
  columnNumber  Int?
  benchIndex    Int?
  columnLabel   String?
  createdAt     DateTime    @default(now())
  examDate      DateTime?
  session       String?
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hall          Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
  examSession   ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, studentId, subjectId])
  @@unique([examSessionId, hallId, seatNumber, examDate, session])
}

model MarkAuditLog {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  oldValue  Float?
  newValue  Float?
  changedBy Int
  timestamp DateTime @default(now())
}

/// Attendance-based exam eligibility (SA Check)
model AttendanceEligibility {
  id                 String   @id @default(cuid())
  studentId          Int
  subjectId          Int
  semester           Int
  attendancePercent  Float
  /// ELIGIBLE | CONDONATION | DETAINED
  status             String
  isException        Boolean  @default(false)
  exceptionReason    String?
  exceptionGrantedBy Int?
  isLocked           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  subject            Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, semester])
  @@index([semester, status])
}

/// HOD notification (sent when attendance is not submitted by faculty)
model Notification {
  id        String   @id @default(cuid())
  hodId     Int
  facultyId Int
  message   String
  isRead    Boolean  @default(false)
  /// ATTENDANCE_MISSING | MARKS_PENDING | GENERAL
  type      String   @default("ATTENDANCE_MISSING")
  createdAt DateTime @default(now())
  faculty   Faculty  @relation("FacultyNotifications", fields: [facultyId], references: [id], onDelete: Cascade)
  hod       Faculty  @relation("HODNotifications", fields: [hodId], references: [id], onDelete: Cascade)

  @@index([hodId, isRead])
}
