// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  username            String    @unique
  password            String
  role                String // "ADMIN" or "FACULTY" or "EXTERNAL_STAFF"
  fullName            String?
  email               String?   @unique
  phoneNumber         String?
  department          String? // Nullable for admin
  designation         String? // e.g. "Professor", "HOD"
  lastPasswordChange  DateTime? @default(now())
  isDisabled          Boolean   @default(false)
  forcePasswordChange Boolean   @default(false)
  lastLogin           DateTime?

  timetables        Timetable[]
  facultyAbsences   FacultyAbsence[]
  substitutions     Substitution[]
  marksApproved     Marks[]             @relation("MarksApprover")
  takenAttendance   StudentAttendance[]
  activityPerformed ActivityLog[]       @relation("PerformedBy")

  announcements Announcement[] @relation("PostedBy")
  materials     Material[]     @relation("Instructor")

  externalStaffTasks ExternalStaffTask[] @relation("ExternalStaffTasks")

  createdAt DateTime @default(now())
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String // e.g. "RESET_PASSWORD", "DISABLE_ACCOUNT"
  description String
  performedBy Int
  performer   User     @relation("PerformedBy", fields: [performedBy], references: [id])
  targetId    Int? // User ID of the faculty affected
  timestamp   DateTime @default(now())
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @unique // e.g. "CSE", "ECE"
  hodId     Int? // User ID of the HOD
  sections  String   @default("A,B,C")
  years     String   @default("2,3,4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id             Int                 @id @default(autoincrement())
  registerNumber String              @unique
  name           String
  department     String?
  year           Int // 1, 2, 3, 4
  section        String // A, B, C
  semester       Int
  createdAt      DateTime            @default(now())
  marks          Marks[]
  attendance     StudentAttendance[]

  results SemesterResult[]
  arrears Arrear[]
}

model Timetable {
  id         Int     @id @default(autoincrement())
  department String?
  year       Int
  semester   Int
  section    String
  day        String // MON, TUE, WED, THU, FRI
  period     Int // 1 to 8
  duration   Int     @default(1) // Number of periods (1 for regular class, 2-3 for labs)
  type       String? // "THEORY", "LAB"

  subjectName String?
  facultyName String? // This could be a direct link to User model if faculty are users
  room        String?

  subjectId Int?
  facultyId Int? // Link to User model for faculty

  subject       Subject?       @relation(fields: [subjectId], references: [id])
  faculty       User?          @relation(fields: [facultyId], references: [id])
  substitutions Substitution[]

  updatedAt DateTime @updatedAt

  @@unique([department, year, semester, section, day, period])
}

model Subject {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique
  name               String
  shortName          String?
  department         String?
  semester           Int
  credits            Int                 @default(3)
  type               String              @default("DEPARTMENT") // "COMMON", "DEPARTMENT"
  marks              Marks[]
  attendance         StudentAttendance[]
  facultyAssignments FacultyAssignment[]
  timetables         Timetable[]
  materials          Material[]

  externalStaffTasks ExternalStaffTask[]
  arrears            Arrear[]
}

model Announcement {
  id       Int    @id @default(autoincrement())
  title    String
  content  String
  category String @default("GENERAL") // GENERAL, EXAM, ACADEMIC, EVENT

  // Targeted audience
  department String? // If null, for all departments
  year       Int? // If null, for all years
  semester   Int? // If null, for all semesters
  section    String? // If null, for all sections

  postedBy Int
  author   User @relation("PostedBy", fields: [postedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String?

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  instructorId Int
  instructor   User @relation("Instructor", fields: [instructorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacultyAssignment {
  id        Int    @id @default(autoincrement())
  facultyId Int
  subjectId Int
  section   String // A, B, C...

  subject Subject @relation(fields: [subjectId], references: [id])
  // We link to User (must be Faculty) manually or via logic, pure relation enforcing role is hard in SQL alone
  // For simplicity we just store the ID, logic will verify it's a faculty
}

model Marks {
  id              Int    @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  cia1_test       Float?
  cia1_assignment Float?
  cia1_attendance Float?

  cia2_test       Float?
  cia2_assignment Float?
  cia2_attendance Float?

  cia3_test       Float?
  cia3_assignment Float?
  cia3_attendance Float?

  internal Float? // Calculated

  // -- DEPRECATED (Keeping for backwards safety during migration, but logic will move to specifics) --
  isLocked   Boolean @default(false)
  isApproved Boolean @default(false)
  // -----------------------------------------------------------------------------------------------

  // Granular Locking & Approval
  isLocked_cia1 Boolean @default(false)
  isLocked_cia2 Boolean @default(false)
  isLocked_cia3 Boolean @default(false)

  isApproved_cia1 Boolean   @default(false)
  isApproved_cia2 Boolean   @default(false)
  isApproved_cia3 Boolean   @default(false)
  approvedBy      Int?
  approvedAt      DateTime?

  updatedAt DateTime @updatedAt

  student  Student @relation(fields: [studentId], references: [id])
  subject  Subject @relation(fields: [subjectId], references: [id])
  approver User?   @relation("MarksApprover", fields: [approvedBy], references: [id])

  endSemMarks EndSemMarks?

  @@unique([studentId, subjectId])
}

model EndSemMarks {
  id            Int     @id @default(autoincrement())
  marksId       Int     @unique
  externalMarks Float? // Marks from the external examination
  totalMarks    Float? // Internal (from Marks) + externalMarks
  grade         String? // Calculated based on totalMarks
  resultStatus  String? // PASS / FAIL

  isPublished Boolean @default(false)
  isLocked    Boolean @default(false)

  updatedAt DateTime @updatedAt

  marks Marks @relation(fields: [marksId], references: [id])
}

model GradeSettings {
  id            Int    @id @default(autoincrement())
  regulation    String // e.g. "2021"
  grade         String // O, A+, A, B+, B, C, U, RA
  minPercentage Float
  maxPercentage Float
  gradePoint    Int
  resultStatus  String @default("PASS") // PASS/FAIL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([regulation, grade])
}

model SemesterControl {
  id         Int    @id @default(autoincrement())
  department String
  year       Int
  semester   Int
  section    String

  markEntryOpen Boolean @default(false)
  isPublished   Boolean @default(false)
  isLocked      Boolean @default(false)
  isFrozen      Boolean @default(false) // Permanent freeze

  actionLogs String? // JSON string of actor, action, timestamp

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([department, year, semester, section])
}

model SemesterResult {
  id            Int    @id @default(autoincrement())
  studentId     Int
  semester      Int
  gpa           Float
  cgpa          Float
  totalCredits  Int
  earnedCredits Int
  resultStatus  String // PASS / FAIL (Current semester overall)

  isLocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, semester])
}

model Arrear {
  id           Int     @id @default(autoincrement())
  studentId    Int
  subjectId    Int
  semester     Int // Semester when it first failed
  attemptCount Int     @default(1)
  isCleared    Boolean @default(false)
  clearedInSem Int? // Semester when it was cleared

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  Student         @relation(fields: [studentId], references: [id])
  subject  Subject         @relation(fields: [subjectId], references: [id])
  attempts ArrearAttempt[]

  @@unique([studentId, subjectId])
}

model ArrearAttempt {
  id            Int     @id @default(autoincrement())
  arrearId      Int
  semester      Int // Semester of attempt
  internalMarks Float?
  externalMarks Float?
  totalMarks    Float?
  grade         String?
  resultStatus  String?

  examDate  DateTime?
  createdAt DateTime  @default(now())

  arrear Arrear @relation(fields: [arrearId], references: [id])
}

model ExternalStaffTask {
  id        Int      @id @default(autoincrement())
  staffId   Int // Link to User with role EXTERNAL_STAFF
  subjectId Int
  deadline  DateTime
  status    String   @default("ASSIGNED") // ASSIGNED, SUBMITTED, UNDER_REVIEW, APPROVED, LOCKED, PRINTED

  questionPaperUrl String?
  remarks          String?

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff   User    @relation("ExternalStaffTasks", fields: [staffId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

// Add these relations back to Student, User, Subject if needed for clarity
// But Prisma will infer them or we add them to the models above

model FacultyAbsence {
  id        Int      @id @default(autoincrement())
  facultyId Int
  date      String // ISO Date String YYYY-MM-DD
  period    Int      @default(0) // 0 = Generic/All Day, >0 = Specific Period
  reason    String?
  createdAt DateTime @default(now())
  faculty   User     @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, date, period])
}

model Substitution {
  id                  Int      @id @default(autoincrement())
  timetableId         Int // Link to original timetable slot
  substituteFacultyId Int // Who is taking the class
  date                String // ISO Date String YYYY-MM-DD
  createdAt           DateTime @default(now())

  timetable         Timetable @relation(fields: [timetableId], references: [id])
  substituteFaculty User      @relation(fields: [substituteFacultyId], references: [id])

  @@unique([timetableId, date])
}

model StudentAttendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  facultyId Int // Who marked it
  date      String // ISO Date String YYYY-MM-DD
  period    Int      @default(0)
  status    String // PRESENT, ABSENT, OD
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  faculty User    @relation(fields: [facultyId], references: [id])

  @@unique([studentId, subjectId, date, period]) // Prevent duplicate entries for same slot
}
