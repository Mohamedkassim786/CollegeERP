# MIET ERP — Backend Environment Variables
# Copy this file to .env and fill in the actual values.
# Never commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to server directory)
DATABASE_URL=file:./dev.db

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_this

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3001

# ─── Academic ─────────────────────────────────────────────────────────────────
# Current academic year (used in exports and reports)
ACADEMIC_YEAR=2024-25

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Directory where uploaded files (student/faculty photos, materials) are stored
UPLOAD_PATH=./uploads
# Maximum upload file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# ─── Logging ──────────────────────────────────────────────────────────────────
# Directory where log files are written (one file per day)
LOG_PATH=./logs
