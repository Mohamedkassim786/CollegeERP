# MIET ERP — Frontend Environment Variables
# Copy this file to .env and fill in the actual values.
# Never commit .env to version control.

# ─── API ──────────────────────────────────────────────────────────────────────
# Backend API base URL. Auto-detects LAN IP when left blank
# For local dev: leave blank (uses window.location.hostname:3000)
# For production: set this to your server's IP or domain
VITE_API_URL=http://localhost:3000/api
